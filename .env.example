# Spring Boot profile (dev | prod | test)
SPRING_PROFILES_ACTIVE=dev

# Database connection (required for prod profile)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/supermercadodb
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_password_here

# Server port (optional, default: 8080)
SERVER_PORT=8080
